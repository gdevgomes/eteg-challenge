# Ambiente da API para desenvolvimento no host (npm run dev).
# Copie para apps/api/.env: cp apps/api/.env.example apps/api/.env
# Hostnames em localhost porque os apps rodam fora do Docker em dev
# (postgres e redis sobem via `docker compose up -d`).

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eteg_db"
REDIS_URL="redis://localhost:6379"

PORT=3000
NODE_ENV=development

BCRYPT_SALT_ROUNDS=10
CPF_HASH_SECRET="dev-cpf-hash-secret"

JWT_SECRET="dev-jwt-secret"
JWT_EXPIRES_IN="8h"
